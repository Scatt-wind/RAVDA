# Server (use 0.0.0.0 when Dify/other Docker services need host access)
HOST=0.0.0.0
PORT=8000

# Dify Agent custom tool base URL (Docker Desktop on Windows/Mac)
# In Dify tool settings use this URL — never http://127.0.0.1:8000 inside containers
DIFY_TOOL_BASE_URL=http://host.docker.internal:8000

# Streamlit frontend (optional)
API_BASE_URL=http://127.0.0.1:8000
STREAMLIT_PORT=8501
API_TIMEOUT_SEC=120

# Dify Agent embed (static web app at /app/)
DIFY_EMBED_URL=http://localhost/chatbot/z8tksm4x2Y2Aqr1E
WEB_POLL_INTERVAL_SEC=4

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# LLM (OpenAI-compatible API; leave OPENAI_API_KEY empty to use rule-based codegen)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SEC=60
MAX_RETRIES=2

# Sandbox
SANDBOX_TIMEOUT_SEC=30
MAX_CHART_COUNT=5

# Conversation
CONVERSATION_DIR=conversations
MAX_CONVERSATION_TURNS=10

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ravda

# RAG (RAGFlow; leave empty to skip retrieval)
RAGFLOW_BASE_URL=
RAGFLOW_API_KEY=
RAGFLOW_EMBEDDING_MODEL=text-embedding-v3@Tongyi-Qianwen
RAG_ENABLED=true
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.2
RAG_INDEX_POLL_INTERVAL_SEC=5
RAG_INDEX_MAX_WAIT_SEC=300